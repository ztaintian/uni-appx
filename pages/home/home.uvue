		font-weight: bold;
	}

	.banner-sub {
		font-size: 28rpx;
		color: rgba(255, 255, 255, 0.9);
		margin-top: 12rpx;
	}

	.category-grid {
		flex-direction: row;
		flex-wrap: wrap;
		background-color: #ffffff;
		margin: 16rpx 24rpx;
		border-radius: 16rpx;
		padding: 24rpx 0 8rpx;
	}

	.category-item {
		width: 20%;
		align-items: center;
		margin-bottom: 24rpx;
	}

	.category-icon-wrap {
		width: 88rpx;
		height: 88rpx;
		border-radius: 44rpx;
		background-color: #fff5f0;
		align-items: center;
		justify-content: center;
	}

	.category-icon {
