<template>
	<view class="page">
		<view class="header">
			<view class="status-bar"></view>
			<view class="search-bar" @click="onSearch">
				<text class="search-icon">🔍</text>
				<text class="search-placeholder">搜索商品、品牌</text>
				<view class="search-btn">
					<text class="search-btn-text">搜索</text>
				</view>
			</view>
		</view>

		<scroll-view class="content" scroll-y="true">
			<swiper class="banner-swiper" circular autoplay interval="3000" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#ffffff">
				<swiper-item v-for="(banner, index) in banners" :key="index">
					<view class="banner-item" :style="{ backgroundColor: banner.color }">
						<text class="banner-title">{{ banner.title }}</text>
						<text class="banner-sub">{{ banner.sub }}</text>
					</view>
				</swiper-item>
			</swiper>

			<view class="category-grid">
				<view class="category-item" v-for="(cat, index) in categories" :key="cat.id" @click="onCategoryClick(cat.id)">
					<view class="category-icon-wrap">
						<text class="category-icon">{{ cat.icon }}</text>
					</view>
					<text class="category-name">{{ cat.name }}</text>
				</view>
			</view>

			<view class="flash-sale">
				<view class="flash-header">
					<text class="flash-title">⚡ 限时秒杀</text>
					<text class="flash-more">更多 ></text>
				</view>
				
			
				<scroll-view class="flash-scroll" :direction="'horizontal'" :show-scrollbar="false">
					<view class="flash-scroll-inner" :style="{ width: flashListWidth }">
						<view class="flash-item" v-for="(item, index) in flashProducts" :key="item.id" @click="goDetail(item.id)">
							<image class="flash-image" :src="item.image" mode="aspectFill"></image>
							<text class="flash-price">¥{{ item.price }}</text>
						</view>
					</view>
				</scroll-view>
				
			</view>

			<view class="product-section">
				<view class="section-header">
					<text class="section-title">猜你喜欢</text>
				</view>
				<view class="product-grid">
					<view class="product-col" v-for="(col, colIndex) in productColumns" :key="colIndex">
						<ProductCard
							v-for="(product, pIndex) in col"
							:key="product.id"
							:product="product"
							@click="goDetail"
						/>
					</view>
				</view>
			</view>

			<view class="bottom-space"></view>
		</scroll-view>

		<AppTabBar currentKey="home" />
	</view>
</template>

<script setup lang="uts">
	import { HOME_CATEGORIES } from '../../constants/categories.uts'
	import { PRODUCTS } from '../../constants/products.uts'
	import { Product } from '../../constants/types.uts'
	import { initCart } from '../../utils/cart.uts'
	import ProductCard from '../../components/ProductCard.uvue'
	import AppTabBar from '../../components/AppTabBar.uvue'

	type Banner = {
		title : string
		sub : string
		color : string
	}

	const banners : Banner[] = [
		{ title: '618 年中大促', sub: '全场满300减50', color: '#ff5000' },
		{ title: '新品首发', sub: '限时抢购 低至5折', color: '#ff2d55' },
		{ title: '品牌盛典', sub: '大牌好物 品质保障', color: '#ff8c00' },
	]

	const categories = HOME_CATEGORIES
	const flashProducts = PRODUCTS.slice(0, 8)
	const flashItemSpace = 210
	const flashListWidth = computed(() : string => {
		return (flashProducts.length * flashItemSpace).toString() + 'rpx'
	})
	const productColumns = computed(() : Product[][] => {
		const left : Product[] = []
		const right : Product[] = []
		for (let i = 0; i < PRODUCTS.length; i++) {
			if (i % 2 == 0) {
				left.push(PRODUCTS[i])
			} else {
				right.push(PRODUCTS[i])
			}
		}
		return [left, right]
	})

	function goDetail(productId : string) {
		uni.navigateTo({
			url: '/pages/product/detail?id=' + productId,
		})
	}

	function onSearch() {
		uni.showToast({
			title: '搜索功能开发中',
			icon: 'none',
		})
	}

	function onCategoryClick(catId : string) {
		uni.reLaunch({
			url: '/pages/category/category',
		})
	}

	onLoad(() => {
		initCart()
	})
</script>

