	}

	.flash-sale {
		background-color: #ffffff;
		margin: 0 24rpx 16rpx;
		border-radius: 16rpx;
		padding: 24rpx 22rpx 28rpx;
	}

	.flash-header {
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 20rpx;
	}

	.flash-title {
		font-size: 30rpx;
		color: #333333;
		font-weight: bold;
	}

	.flash-more {
		font-size: 24rpx;
		color: #999999;
	}

	.flash-swiper {
		width: 100%;
		height: 220rpx;
	}

	.flash-scroll {
		width: 100%;
		height: 220rpx;
	}

	.flash-scroll-inner {
		height: 220rpx;
		flex-direction: row;
	}

	.flash-item {
		width: 190rpx;
		margin-right: 20rpx;
		align-items: center;
	}

	.flash-swiper-item {
		margin-right: 0;
	}

	.flash-image {
		width: 176rpx;
		height: 176rpx;
		border-radius: 14rpx;
	}

	.flash-price {
